server {
    listen 80;
    server_name apisupportrobbit.asatullayev.uz;

    location = /favicon.ico { access_log off; log_not_found off; }
    location /static/ {
        root /root/SupportBooking/staticfiles;
    }
    location /media/ {
        alias /root/SupportBooking/media;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/run/support.sock;
    }
}